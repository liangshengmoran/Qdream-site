# 数据库文件路径
DATABASE_PATH=./data/dream-site.db

# JWT 密钥 (请替换为随机字符串, 至少 32 字符)
JWT_SECRET=change-me-to-a-random-secret-string

# 服务端口 (默认 5173)
PORT=5173

# 项目名称
NEXT_PUBLIC_APP_NAME = 'Dream Site'
# 项目描述
NEXT_PUBLIC_APP_DESC = '一个以极简设计呈现的现代化个人导航站，帮助你高效访问常用网站与优质资源。'
# 项目关键词
NEXT_PUBLIC_APP_KEYWORDS = 'Dream Site,极简导航,网站导航,个人站点,书签管理,资源导航,Next.js'
# 项目域名
NEXT_PUBLIC_APP_URL = ''
# 版权
NEXT_PUBLIC_COPYRIGHT = "清韵's"
# 网站ICP
NEXT_PUBLIC_ICP = ''
# 网站公网备案
NEXT_PUBLIC_GUAN_ICP = ''
# Umami ID (可选)
NEXT_PUBLIC_UMAMI_ID = ''
# Google Analytics ID (可选)
NEXT_PUBLIC_GOOGLE_ID = ''
# Microsoft Clarity ID (可选)
NEXT_PUBLIC_CLARITY_ID = ''
